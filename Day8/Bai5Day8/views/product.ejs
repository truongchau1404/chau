<!DOCTYPE html>  												
<html lang="en">  												
<head>  												
    <meta charset="UTF-8">  												
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  												
    <title>Danh sách Sản phẩm</title>  												
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>  												
<body class="bg-light">  												
    <div class="container mt-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h2 class="mb-0">Quản lý Sản phẩm</h2>
                <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">Thêm mới</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">  												
                        <thead class="table-dark">
                            <tr>  												
                                <th>ID</th>  												
                                <th>Tên sản phẩm</th>  												
                                <th>Giá bán</th>  												
                                <th>Mô tả</th>  												
                                <th>Thao tác</th>
                            </tr>  												
                        </thead>
                        <tbody>
                            <% if (products && products.length > 0) { %>
                                <% products.forEach(product => { %>  												
                                <tr>  												
                                    <td><span class="badge bg-secondary"><%= product.id %></span></td>  												
                                    <td class="fw-bold text-dark"><%= product.name %></td>  												
                                    <td class="text-danger fw-bold"><%= (product.price || 0).toLocaleString('vi-VN') %> đ</td>  												
                                    <td class="text-muted"><%= product.description %></td>  												
                                    <td>
                                        <a href="/delete/<%= product.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">Xóa</a>
                                    </td>
                                </tr>  												
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">Không có dữ liệu sản phẩm để hiển thị.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>  												
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Thêm Sản Phẩm -->
    <div class="modal fade" id="addModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm sản phẩm mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/add" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Tên sản phẩm</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Giá bán</label>
                            <input type="number" name="price" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mô tả</label>
                            <textarea name="description" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-primary">Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>  												
												